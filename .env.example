# .env.example
# 复制此文件为 .env 并填入真实密钥，切勿将 .env 上传到 GitHub！

# --- 大模型 API 配置 ---
# 推荐使用国产模型（如通义千问、智谱），对学生更友好且有免费额度
# 若使用 OpenAI，请填写 https://api.openai.com/v1
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL_NAME=qwen-turbo

# --- 数据生成参数 ---
# 每次生成对话的最大轮数
MAX_DIALOGUE_TURNS=10
# 生成数据的保存路径
OUTPUT_DATA_DIR=data/generated

# --- 情感标签体系 ---
# 定义本项目支持的情感类别，用于 Prompt 约束
EMOTION_LABELS=anxiety,empathy,neutral,sad,hopeful